[disk]
label=💾 
command=df -h / | awk 'NR==2 {print $4}'
interval=30
color=#2ECC71

# Використання оперативної пам'яті (RAM)
[memory]
label=🧠 
command=free -h | awk '/^Mem:/ {print $3 "/" $2}'
interval=10
color=#3498DB

