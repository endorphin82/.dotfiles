# Бездротова мережа (Wi-Fi)
[wifi]
label=📶 
command=WLAN=$(ip route | awk '/default/ {print $5}' | grep '^w'); if [ -n "$WLAN" ]; then iwgetid -r $WLAN; else echo "down"; fi
interval=10
color=#3498DB

[cpu_usage]
interval=1
command=./cpu.sh
min_width=⣾⣄ 100.00%

# Температура процесора (важливо для ноутбуків)
[temperature]
label=🌡️ 
command=sensors | awk '/Core 0/ {print $3}'
interval=1
color=#E74C3C

# Рівень гучності (PipeWire / Audio)
[volume]
# label=🔊 
# command=wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{print int($2*100)"%"}'
command=MUTED=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ | grep -o "MUTED"); VOL=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{print int($2*100)}'); if [ "$MUTED" = "MUTED" ] || [ "$VOL" -eq 0 ]; then echo "🔇 MUTE"; else echo "🔊 $VOL%"; fi
interval=once
signal=10
color=#2ECC71

# Стан батареї (динамічний колір залежно від розряду)
[battery]
command=STATUS=$(acpi -b | awk -F, '{print $1}' | awk '{print $3}'); PERC=$(acpi -b | awk -F, '{print $2}' | tr -d ' %'); if [ "$STATUS" = "Charging" ]; then echo "⚡ $PERC%"; elif [ "$PERC" -le 20 ]; then echo "🪫 $PERC%"; else echo "🔋 $PERC%"; fi
interval=10
color=#E67E22

# Дата та час
[time]
label=📅 
# command=date '+%d.%m %H:%M'
command=date '+%A_%u %B_%m %d %H:%M'
interval=5
color=#1ABC9C
